# Backend Environment Variables
# Copy this file to .env and update with your values

# Server
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=sqlite:///digital_debt_tracker.db

# JWT
JWT_SECRET=change-this-to-a-very-long-random-string-in-production
JWT_REFRESH_SECRET=change-this-to-another-very-long-random-string-in-production

# CORS
CORS_ORIGIN=http://localhost:3000

# Email (for future alerts feature)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
